# =============================================================================
# TEMPLATE DE CONFIGURACIÓN DE ENTORNO
# =============================================================================
# Copia este archivo como `.env` y completa los valores según tu entorno.
#
# DESARROLLO LOCAL: Usa valores locales (localhost, Docker, etc.)
# PRODUCCIÓN: Configura las variables en Render/Railway dashboard
# =============================================================================

# =========================
# Entorno activo (opcional)
# =========================
# SPRING_PROFILES_ACTIVE=dev

# =========================
# MySQL Container (solo desarrollo local con Docker)
# =========================
# ⚡ IMPORTANTE: Estas variables se reutilizan automáticamente en DB_URL, DB_USER y DB_PASS
#    Define estos valores una vez y todo se actualiza automáticamente.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=template_shop
MYSQL_USER=hadmin
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD

# =========================
# Base de Datos
# =========================
# ⚡ Usa ${VARIABLE} para referenciar valores definidos arriba
# DESARROLLO (local o Docker):
DB_URL=jdbc:mysql://localhost:3306/${MYSQL_DATABASE}?createDatabaseIfNotExist=true&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USER=${MYSQL_USER}
DB_PASS=${MYSQL_PASSWORD}
DB_DIALECT=org.hibernate.dialect.MySQLDialect
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_SHOW_SQL=true
DB_HBM2DDL=update

# PRODUCCIÓN (Railway/PlanetScale):
# DB_URL=jdbc:mysql://HOST:PORT/DATABASE?useSSL=true&requireSSL=true&serverTimezone=UTC
# DB_USER=YOUR_DB_USER
# DB_PASS=YOUR_DB_PASSWORD
# DB_SHOW_SQL=false
# DB_HBM2DDL=update

# =========================
# Servidor y Rutas
# =========================
# DESARROLLO:
# ⚡ Ruta base para uploads - Define solo esto una vez
UPLOADS_BASE_PATH=C:/uploads

# ⚡ Rutas específicas - Usan ${UPLOADS_BASE_PATH} automáticamente (no cambiar)
IMAGES_STORAGE_PATH=${UPLOADS_BASE_PATH}/images
INVOICES_STORAGE_PATH=${UPLOADS_BASE_PATH}/invoices

APP_BASE_URL=http://localhost:8080
APP_IMAGES_PUBLIC_PATH=/images
APP_FRONTEND_URL=http://localhost:5500

# PRODUCCIÓN:
# UPLOADS_BASE_PATH=/opt/render/project/src/uploads
# IMAGES_STORAGE_PATH=${UPLOADS_BASE_PATH}/images
# INVOICES_STORAGE_PATH=${UPLOADS_BASE_PATH}/invoices
# APP_BASE_URL=https://your-backend.onrender.com
# APP_FRONTEND_URL=https://your-frontend.vercel.app

# =========================
# CORS
# =========================
# DESARROLLO:
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# PRODUCCIÓN:
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend-*.vercel.app

# =========================
# JWT
# =========================
# Genera un secret seguro con: openssl rand -hex 32
jwt.secret=YOUR_JWT_SECRET_KEY_HERE
jwt.expiration=3600000

# =========================
# Usuarios de Sistema (seed inicial)
# =========================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
ADMIN_PHONE=+34000000001

SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
SUPER_ADMIN_PHONE=+34000000000

# =========================
# Mail (Gmail SMTP)
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=YOUR_APP_PASSWORD

# =========================
# Google OAuth2 (para Gmail XOAUTH2)
# =========================
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN

# =========================
# Company Info (Facturas)
# =========================
COMPANY_NAME=Your Company Name
COMPANY_NIF=B12345678
COMPANY_ADDRESS=Calle Ejemplo 1, 28001 Madrid, España
COMPANY_EMAIL=info@example.com
COMPANY_PHONE=+34 000 00 00 00
COMPANY_IBAN=ES00 0000 0000 0000 0000 0000
COMPANY_PRIMARY_COLOR=#1A73E8
COMPANY_SECONDARY_COLOR=#E8F0FE
COMPANY_ACCENT_COLOR=#FBBC04
COMPANY_TEXT_COLOR=#202124
COMPANY_LOGO_PATH=

# =========================
# Stripe
# =========================
# DESARROLLO (test keys):
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_CURRENCY=eur

# PRODUCCIÓN (live keys):
# STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_CURRENCY=eur
